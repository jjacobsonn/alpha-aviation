# Copy to frontend/.env and fill in values.
# Do not commit frontend/.env if it contains non-public URLs.
#
# Create React App only exposes variables prefixed with REACT_APP_.
# Rebuild the frontend after changing this file (yarn build / Render deploy).

# Backend API base URL including the /api path (no trailing slash).
# Local:
REACT_APP_API_URL=http://127.0.0.1:8000/api

# Production (Render static site) example:
# REACT_APP_API_URL=https://alpha-aviation-dev.onrender.com/api
