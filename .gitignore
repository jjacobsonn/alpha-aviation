# --- Dependencies (never commit installed trees) ---
node_modules/
**/node_modules/

# --- Lock files ---
# Ignore npm lockfiles (this repo uses Yarn in frontend, Poetry in backend).
package-lock.json
**/package-lock.json

# Keep frontend/yarn.lock and backend/poetry.lock in git — Railway Docker builds
# use them for reproducible installs (see frontend/Dockerfile, Dockerfile.railway-api).

# --- Environment & secrets (never commit real values) ---
.env
.env.*
!.env.example
!**/.env.example
backend/.env
frontend/.env
.auth/
*.pem
**/serviceAccountKey.json
**/credentials.json

# --- Python ---
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
.Python
.venv/
venv/
env/
.pytest_cache/
htmlcov/
.coverage
*.egg-info/
.mypy_cache/
.ruff_cache/

# --- Frontend build & tooling ---
frontend/build/
build/
coverage/
*.tsbuildinfo

# --- Logs ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- OS ---
.DS_Store
Thumbs.db

# --- IDE / editor ---
.idea/
.vscode/
*.swp
*.swo
*~
*.code-workspace
.claude/
.cursor/

# --- E2E ---
test-results/
playwright-report/
blob-report/
playwright/.cache/
