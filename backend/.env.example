# Copy to .env and fill in values. Required for the app to start.

# Django
SECRET_KEY=your-secret-key-change-in-production
DEBUG=True

# Database (PostgreSQL)
DB_NAME=aviation
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Optional: comma-separated list (default allows localhost for dev)
# ALLOWED_HOSTS=localhost,127.0.0.1
