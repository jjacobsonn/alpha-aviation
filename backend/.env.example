# Copy to backend/.env and fill in values.
# Do not commit backend/.env (secrets).
#
# Variable reference: docs/deployment/DEPLOYMENT.md
# Local setup: docs/setup/DEVELOPMENT.md

# --- Required (all environments) ---

# Django secret key. Use a long random value in production.
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-change-in-production

# Local development: True. Render/production: False
DEBUG=True

# --- Database (use ONE approach) ---

# Production (Render): set DATABASE_URL to the Postgres Internal Database URL.
# When DATABASE_URL is set, DB_NAME / DB_USER / DB_PASSWORD / DB_HOST / DB_PORT are ignored.
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Local development: leave DATABASE_URL unset and use PostgreSQL credentials below.
DB_NAME=aviation
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# --- Host / CORS (optional; defaults work for localhost) ---

# Comma-separated hostnames the API accepts (no scheme, no port unless non-default).
# Default if unset: localhost,127.0.0.1
# Production example: alpha-aviation-dev.onrender.com
# ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated frontend origins allowed by CORS (scheme required, no trailing slash).
# localhost:3000 and 127.0.0.1:3000 are always allowed in addition to this list.
# Production example: https://alpha-aviation-dev-1.onrender.com
# CORS_ALLOWED_ORIGINS=https://your-frontend.onrender.com

# --- Optional (not used by current settings.py; future paid Render disk) ---

# When you upgrade to a paid Render web service with a persistent disk mounted at /var/data:
# MEDIA_ROOT=/var/data/media
